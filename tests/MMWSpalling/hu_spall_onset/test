#!/usr/bin/env python3
# Step 11b: Hu LRST/onset validation using ALAMO DP damage.
#
# This v1 validation keeps spall removal off and uses first shallow,
# surface-connected D-threshold crossing as the onset proxy. The inputs are
# homogeneous one-phase microstructures so the ALAMO damage fields exist
# without introducing Voronoi heterogeneity.

import glob
import math
import os
import re
import shutil
import subprocess
import sys

import numpy as np
import yt

yt.funcs.mylog.setLevel(40)

ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", "..", ".."))
TEST_DIR = os.path.join(ROOT, "tests", "MMWSpalling", "hu_spall_onset")
BIN = os.path.join(ROOT, "bin", "mmwspalling-3d-g++")
OUT_ROOT = os.path.join(TEST_DIR, "output")

PATCH_X0 = 0.05
PATCH_Y0 = 0.05
PATCH_RADIUS = 0.015
Z_TOP = 0.10
D_THRESHOLD = 0.50
SHALLOW_DEPTH = 0.006
MAX_DAMAGE_DEPTH = 0.008
DEPTH_WARNING_ONLY = True

CASES = {
    "granite2": {
        "label": "Granite 2",
        "input": os.path.join(TEST_DIR, "input_granite2"),
        "outdir": os.path.join(OUT_ROOT, "granite2"),
        "T_expr": lambda t: 638.22 + 3.74 * t,
        "hu_primary_onset": 37.0,
        "hu_primary_lrst": 773.15,
        "target_onset": 31.5,
        "onset_tol": 0.20,
        "target_lrst": 791.48,
        "lrst_tol": 0.10,
    },
    "sandstone2": {
        "label": "Sandstone 2",
        "input": os.path.join(TEST_DIR, "input_sandstone2"),
        "outdir": os.path.join(OUT_ROOT, "sandstone2"),
        "T_expr": lambda t: 684.64 + 2.46 * t,
        "hu_primary_onset": 89.0,
        "hu_primary_lrst": 893.15,
        # target_onset = Hu primary sandstone case (89.0 s) under the 32^3
        # input now used by Step 12+; the Hu average (76.7 s, excluding the
        # sandstone-4 outlier) was the Step 11b 40^3 calibration target and
        # was tightened against that resolution.
        "target_onset": 89.0,
        "onset_tol": 0.20,
        "target_lrst": 842.40,
        "lrst_tol": 0.10,
    },
}


def plotfiles(outdir):
    pat = re.compile(r"(\d+)cell$")
    cands = []
    for path in glob.glob(os.path.join(outdir, "*cell")):
        m = pat.search(os.path.basename(path))
        if m:
            cands.append((int(m.group(1)), path))
    cands.sort()
    return [p for _, p in cands]


def run_alamo(case):
    if not os.path.exists(BIN):
        print(f"FAIL: missing binary {BIN}; build first")
        sys.exit(1)
    if os.path.isdir(case["outdir"]):
        shutil.rmtree(case["outdir"])
    cmd = [
        "mpirun", "--oversubscribe", "--bind-to", "none", "-np", "4",
        BIN, case["input"],
    ]
    print("Running:", " ".join(cmd))
    env = os.environ.copy()
    env.setdefault("OMPI_MCA_btl", "self,vader,tcp")
    res = subprocess.run(cmd, cwd=ROOT, env=env)
    if res.returncode != 0:
        print(f"FAIL: ALAMO run for {case['label']} exited with {res.returncode}")
        sys.exit(res.returncode)


def to_numpy(arr):
    return np.asarray(arr.to_value() if hasattr(arr, "to_value") else arr)


def load_damage_metrics(path):
    ds = yt.load(path)
    ad = ds.all_data()
    x = to_numpy(ad["x"])
    y = to_numpy(ad["y"])
    z = to_numpy(ad["z"])
    D = to_numpy(ad["D"])
    Temp = to_numpy(ad["Temp"])
    depth = Z_TOP - z
    r2 = (x - PATCH_X0) ** 2 + (y - PATCH_Y0) ** 2
    heated = r2 <= PATCH_RADIUS ** 2 + 1.0e-14
    shallow = heated & (depth >= -1.0e-12) & (depth <= SHALLOW_DEPTH + 1.0e-12)
    damaged = D >= D_THRESHOLD
    shallow_damaged = shallow & damaged
    max_depth = 0.0
    if np.any(heated & damaged):
        max_depth = float(np.max(depth[heated & damaged]))
    return {
        "time": float(ds.current_time),
        "path": path,
        "max_D_shallow": float(np.max(D[shallow])) if np.any(shallow) else 0.0,
        "max_D_heated": float(np.max(D[heated])) if np.any(heated) else 0.0,
        "mean_D_shallow": float(np.mean(D[shallow])) if np.any(shallow) else 0.0,
        "surface_connected": bool(np.any(shallow_damaged)),
        "max_damage_depth": max_depth,
        "n_shallow_damaged": int(np.count_nonzero(shallow_damaged)),
        "max_T_heated": float(np.max(Temp[heated])) if np.any(heated) else float(np.max(Temp)),
    }


def analyze_case(case):
    files = plotfiles(case["outdir"])
    if not files:
        print(f"FAIL: no cell plotfiles found in {case['outdir']}")
        sys.exit(1)

    series = [load_damage_metrics(p) for p in files]
    onset = None
    for item in series:
        crossed = item["max_D_shallow"] >= D_THRESHOLD
        if crossed and item["surface_connected"]:
            onset = item
            break

    if onset is None:
        final = series[-1]
        return {
            "case": case,
            "ok": False,
            "reason": (
                f"no shallow surface-connected D >= {D_THRESHOLD:.2f}; "
                f"final max shallow D = {final['max_D_shallow']:.3f}"
            ),
            "series": series,
            "onset": None,
        }

    t_on = onset["time"]
    lrst = case["T_expr"](t_on)
    return {
        "case": case,
        "ok": True,
        "series": series,
        "onset": onset,
        "onset_time": t_on,
        "lrst": lrst,
        "max_damage_depth": onset["max_damage_depth"],
        "max_D_shallow": onset["max_D_shallow"],
        "mean_D_shallow": onset["mean_D_shallow"],
    }


def check_case(result):
    case = result["case"]
    if not result["ok"]:
        print(f"{case['label']}: FAIL: {result['reason']}")
        return False

    t = result["onset_time"]
    lrst = result["lrst"]
    onset_lo = case["target_onset"] * (1.0 - case["onset_tol"])
    onset_hi = case["target_onset"] * (1.0 + case["onset_tol"])
    lrst_lo = case["target_lrst"] * (1.0 - case["lrst_tol"])
    lrst_hi = case["target_lrst"] * (1.0 + case["lrst_tol"])
    depth_mm = 1000.0 * result["max_damage_depth"]

    print(
        f"{case['label']}: onset={t:.1f} s "
        f"(Hu primary {case['hu_primary_onset']:.1f} s; "
        f"avg window {onset_lo:.1f}..{onset_hi:.1f} s), "
        f"LRST={lrst:.2f} K "
        f"(Hu primary {case['hu_primary_lrst']:.2f} K; "
        f"avg window {lrst_lo:.2f}..{lrst_hi:.2f} K), "
        f"damage depth={depth_mm:.2f} mm, "
        f"max shallow D={result['max_D_shallow']:.3f}"
    )

    ok = True
    if not (onset_lo <= t <= onset_hi):
        ok = False
        print(f"FAIL: {case['label']} onset outside average Hu tolerance window")
    if not (lrst_lo <= lrst <= lrst_hi):
        ok = False
        print(f"FAIL: {case['label']} LRST outside average Hu tolerance window")
    if result["max_damage_depth"] > MAX_DAMAGE_DEPTH + 1.0e-12:
        msg = (
            f"{case['label']} damage depth {depth_mm:.2f} mm exceeds "
            f"{1000.0 * MAX_DAMAGE_DEPTH:.2f} mm"
        )
        if DEPTH_WARNING_ONLY:
            print(f"WARNING: {msg}; kept reporting-only for Step 11b v1")
        else:
            ok = False
            print(f"FAIL: {msg}")
    return ok


def plot_results(results):
    try:
        import matplotlib

        matplotlib.use("Agg")
        import matplotlib.pyplot as plt
    except ImportError:
        print("(matplotlib not installed - skipping PNG plot)")
        return

    labels = [results[k]["case"]["label"] for k in ("granite2", "sandstone2")]
    sim_onset = [results[k].get("onset_time", math.nan) for k in ("granite2", "sandstone2")]
    hu_onset = [results[k]["case"]["hu_primary_onset"] for k in ("granite2", "sandstone2")]
    sim_lrst = [results[k].get("lrst", math.nan) for k in ("granite2", "sandstone2")]
    hu_lrst = [results[k]["case"]["hu_primary_lrst"] for k in ("granite2", "sandstone2")]
    depth = [
        1000.0 * results[k].get("max_damage_depth", math.nan)
        for k in ("granite2", "sandstone2")
    ]

    x = np.arange(len(labels))
    width = 0.36
    fig, axes = plt.subplots(1, 3, figsize=(13.5, 4.2))

    axes[0].bar(x - width / 2, sim_onset, width, label="ALAMO")
    axes[0].bar(x + width / 2, hu_onset, width, label="Hu primary")
    axes[0].set_xticks(x, labels)
    axes[0].set_ylabel("onset time [s]")
    axes[0].set_title("Damage-threshold onset")
    axes[0].legend()

    axes[1].bar(x - width / 2, sim_lrst, width, label="ALAMO")
    axes[1].bar(x + width / 2, hu_lrst, width, label="Hu primary")
    axes[1].set_xticks(x, labels)
    axes[1].set_ylabel("LRST [K]")
    axes[1].set_title("Surface temperature at onset")
    axes[1].legend()

    axes[2].bar(x, depth, width=0.55, color=["C0", "C1"])
    axes[2].axhline(1000.0 * MAX_DAMAGE_DEPTH, color="0.3", ls="--", lw=1.0)
    axes[2].set_xticks(x, labels)
    axes[2].set_ylabel("damage-zone depth [mm]")
    axes[2].set_title(f"Depth at D >= {D_THRESHOLD:.2f}")

    fig.tight_layout()
    out_png = os.path.join(OUT_ROOT, "comparison.png")
    os.makedirs(OUT_ROOT, exist_ok=True)
    fig.savefig(out_png, dpi=140)
    print(f"wrote {out_png}")


def main():
    manual = len(sys.argv) > 1
    if manual:
        CASES["granite2"]["outdir"] = sys.argv[1]
        CASES["sandstone2"]["outdir"] = sys.argv[2] if len(sys.argv) > 2 else CASES["sandstone2"]["outdir"]
    else:
        for case in CASES.values():
            run_alamo(case)

    results = {name: analyze_case(case) for name, case in CASES.items()}
    ok = True
    ok = check_case(results["granite2"]) and ok
    ok = check_case(results["sandstone2"]) and ok

    g_on = results["granite2"].get("onset_time", math.inf)
    s_on = results["sandstone2"].get("onset_time", -math.inf)
    print(f"material ordering: granite onset {g_on:.1f} s, sandstone onset {s_on:.1f} s")
    if not (g_on < s_on):
        ok = False
        print("FAIL: Granite 2 did not reach damage threshold before Sandstone 2")

    plot_results(results)
    print()
    print("PASS" if ok else "FAIL")
    return 0 if ok else 1


if __name__ == "__main__":
    sys.exit(main())
