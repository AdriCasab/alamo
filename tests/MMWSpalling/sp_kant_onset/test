TEST_DIR = os.path.join(ROOT, "tests", "MMWSpalling", "sp_kant_onset")
BIN = os.path.join(ROOT, "bin", "mmwspalling-3d-g++")
OUT_ROOT = os.path.join(TEST_DIR, "output")

# --- constants, mirror the input files -------------------------------------
T_I      = 293.15           # K, initial / room temperature
E        = 35.0e9           # Pa, Central Aare granite (mean bracket)
NU       = 0.26             # Poisson (mean bracket)
ALPHA    = 8.0e-6           # 1/K, linear thermal expansion
A_FLAW   = 20.0e-6          # m, deterministic flaw length (Moeri 2003)
I_FK     = 1.763            # integral_0^1 f_K(xi) dxi  (Kant Eq. 15)
KIC0_PA  = 1.5e6            # Pa.m^0.5, frozen room-T K_Ic0 (Kant Table 1)
KIC_SCALE = 1.05            # Central Aare scaling on the Nasseri table
Z_TOP    = 0.024            # m, +z face

# Kant predicted band (Table 2) and measured anchor (do NOT score on measured)
BAND_LO, BAND_HI = 390.0, 560.0
MEAS_LO, MEAS_HI = 553.0, 694.0

TOL_EQ15  = 0.08    # target 3: FEM onset dT vs Kant Eq. 15
TOL_HFL   = 0.08    # target 5: onset dT across two h_fl values
PATCH_MIN_FIRE = 5  # target 6: >= 5 distinct firing locations

# Nasseri 2007 Westerly-granite K_Ic(T) table (raw; the FEM applies x1.05).
NAS_TK = np.array([298.15, 523.15, 723.15, 923.15, 1123.15])
NAS_K  = np.array([1.43, 1.35, 0.98, 0.43, 0.22])


def kic_nasseri_pa(T_K):
    """Scaled Nasseri K_Ic(T), endpoint-clamped, in Pa.m^0.5."""
    return KIC_SCALE * np.interp(T_K, NAS_TK, NAS_K) * 1.0e6


def theta15_frozen(kic_pa=KIC0_PA, a=A_FLAW, e=E, nu=NU):
    """Kant Eq. 15 onset dT with a frozen (T-independent) K_Ic."""
    return kic_pa * (1.0 - nu) / (2.0 * I_FK * math.sqrt(a / math.pi) * e * ALPHA)


def theta15_kict(a=A_FLAW, e=E, nu=NU):
    """Kant Eq. 15 onset dT with the K_Ic(T) table (implicit; fixed-point)."""
    th = 400.0
    for _ in range(500):
        th = float(kic_nasseri_pa(T_I + th)) * (1.0 - nu) \
            / (2.0 * I_FK * math.sqrt(a / math.pi) * e * ALPHA)
    return th


