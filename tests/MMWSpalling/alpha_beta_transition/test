#!/usr/bin/env python3
# Regression for quartz alpha-beta transformation eigenstrain.

import glob
import os
import re
import sys

import numpy as np
import yt


def latest_plotfile(outdir):
    pat = re.compile(r"(\d+)cell$")
    cands = []
    for path in glob.glob(os.path.join(outdir, "*cell")):
        match = pat.search(os.path.basename(path))
        if match:
            cands.append((int(match.group(1)), path))
    if not cands:
        return None
    cands.sort()
    return cands[-1][1]


outdir = sys.argv[1] if len(sys.argv) > 1 else \
    "tests/MMWSpalling/alpha_beta_transition/output"
plotfile = latest_plotfile(outdir)
if not plotfile:
    print("FAIL: no cell plotfiles in", outdir)
    sys.exit(1)

ds = yt.load(plotfile)
cg = ds.covering_grid(level=0,
                      left_edge=ds.domain_left_edge,
                      dims=ds.domain_dimensions)

phase = np.asarray(cg["phase"]).astype(int)
eps = np.asarray(cg["thermal_free_strain"])

expected = (1.0 + 0.0063) ** (1.0 / 3.0) - 1.0
quartz = phase == 0
feldspar = phase == 1

ok = True
q_err = float(np.max(np.abs(eps[quartz] - expected)))
f_max = float(np.max(np.abs(eps[feldspar])))

print(f"Loaded {plotfile} at t={float(ds.current_time):.3f}")
print(f"expected quartz alpha-beta linear strain = {expected:.8e}")
print(f"max quartz strain error = {q_err:.3e}")
print(f"max inert-phase strain  = {f_max:.3e}")

if q_err > 1.0e-10:
    ok = False
    print("FAIL: quartz phase did not receive the alpha-beta strain")
if f_max > 1.0e-12:
    ok = False
    print("FAIL: inert phase received nonzero alpha-beta strain")

print()
print("PASS" if ok else "FAIL")
sys.exit(0 if ok else 1)
