#!/usr/bin/env python3
# Step 11: vaporisation removal and unified RoP regression.
#
# Low-power case: spall fires (D >= D_th and ratio >= xi_s), vapor below
# threshold (H < H_vap because T < T_vap_lo). Expect regime = 1, RoP_vap
# zero, RoP = RoP_spall on detached cells.
#
# High-power case: vapor fires (H >= H_vap because T > T_vap_lo), spall
# suppressed (D = 0). Expect regime = 2, RoP_spall zero, and RoP_vap close
# to the closed-form (1-R)*P0 / (rho*L_tot*A_beam).

import glob
import math
import os
import re
import shutil
import subprocess
import sys

import numpy as np
import yt

yt.funcs.mylog.setLevel(40)

ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", "..", ".."))
TEST_DIR = os.path.join(ROOT, "tests", "MMWSpalling", "regime_low_high_power")
INPUT_LOW  = os.path.join(TEST_DIR, "input_low_power")
INPUT_HIGH = os.path.join(TEST_DIR, "input_high_power")
OUT_LOW  = os.path.join(TEST_DIR, "output_low_power")
OUT_HIGH = os.path.join(TEST_DIR, "output_high_power")
BIN = os.path.join(ROOT, "bin", "mmwspalling-3d-g++")

DZ = 1.0 / 8.0
T_AMB = 300.0
H_SPALL = 0.25 * math.sqrt(1.0 * 1.0)  # C_h * sqrt(alpha * t_spall)

# High-power closed form: rho=1, Cp=1, T_vap_lo=2000, T0=300, L_m=L_v=0,
# A_beam=1, R=0, P0=425.
RHO   = 1.0
CP    = 1.0
T_VAP = 2000.0
T0    = 300.0
L_TOT = CP * (T_VAP - T0)  # 1700
A_BEAM = 1.0
R_BEAM = 0.0
P0    = 425.0
ROP_VAP_EXPECTED = (1.0 - R_BEAM) * P0 / (RHO * L_TOT * A_BEAM)
H_VAP_EXPECTED   = ROP_VAP_EXPECTED * 1.0  # dt = 1.0


def plotfiles(outdir):
    pat = re.compile(r"(\d+)cell$")
    cands = []
    for path in glob.glob(os.path.join(outdir, "*cell")):
        m = pat.search(os.path.basename(path))
        if m:
            cands.append((int(m.group(1)), path))
    cands.sort()
    return [p for _, p in cands]


def run_alamo(input_path, outdir):
    if not os.path.exists(BIN):
        print(f"FAIL: missing binary {BIN}; build first")
        sys.exit(1)
    if os.path.isdir(outdir):
        shutil.rmtree(outdir)
    # Step 11 makes the per-column update parallel-correct via
    # ReduceIntMax / ReduceRealSum on per-(i,j) buffers, so we
    # exercise a 4-rank run by default.
    cmd = ["mpirun", "--oversubscribe", "--bind-to", "none", "-np", "4",
           BIN, input_path]
    print("Running:", " ".join(cmd))
    env = os.environ.copy()
    env.setdefault("OMPI_MCA_btl", "self,vader,tcp")
    res = subprocess.run(cmd, cwd=ROOT, env=env)
    if res.returncode != 0:
        print(f"FAIL: ALAMO run for {input_path} exited with {res.returncode}")
        sys.exit(res.returncode)


def load_plot(path, fields):
    ds = yt.load(path)
    cg = ds.covering_grid(level=0,
                          left_edge=ds.domain_left_edge,
                          dims=ds.domain_dimensions)
    out = {"path": path, "time": float(ds.current_time)}
    for f in fields:
        out[f] = np.asarray(cg[f])
    return out


FIELDS = ["phi", "removed", "regime", "RoP", "RoP_spall", "RoP_vap",
          "spall_event", "spall_thickness", "vapor_event",
          "vapor_thickness", "D", "Temp", "surface"]

ok = True

run_low_outdir  = sys.argv[1] if len(sys.argv) > 1 else OUT_LOW
manual = (run_low_outdir == OUT_LOW)
if manual:
    run_alamo(INPUT_LOW,  OUT_LOW)
    run_alamo(INPUT_HIGH, OUT_HIGH)

# ---------------------------------------------------------------- low-power
files_low = plotfiles(OUT_LOW)
if not files_low:
    print("FAIL: no plotfiles in", OUT_LOW)
    sys.exit(1)
final_low = load_plot(files_low[-1], FIELDS)
nx, ny, nz = final_low["phi"].shape

# Detached cells: top two of every column.
expected_removed = np.zeros_like(final_low["removed"])
expected_removed[:, :, nz - 2:] = 1.0
det_low = expected_removed > 0.5
non_low = ~det_low

if not np.array_equal(final_low["removed"], expected_removed):
    ok = False
    print("FAIL: low-power removed mask differs from expected top-2 layer")

# Regime should be 1 on detached cells, 0 elsewhere.
if not np.all(final_low["regime"][det_low] == 1.0):
    ok = False
    print("FAIL: low-power regime != 1 on every detached cell")
if float(np.max(np.abs(final_low["regime"][non_low]))) > 0.0:
    ok = False
    print("FAIL: low-power regime nonzero outside detached cells")

# Spall fires; vapor does not.
if not np.all(final_low["spall_event"][det_low] == 1.0):
    ok = False
    print("FAIL: low-power spall_event != 1 on detached cells")
if not np.all(np.isclose(final_low["spall_thickness"][det_low], H_SPALL,
                         atol=1.0e-12)):
    ok = False
    print("FAIL: low-power spall_thickness != h_spall on detached cells")
if not np.all(np.isclose(final_low["RoP_spall"][det_low], H_SPALL,
                         atol=1.0e-12)):
    ok = False
    print("FAIL: low-power RoP_spall != h_spall/dt on detached cells")
if float(np.max(np.abs(final_low["vapor_event"]))) > 0.0:
    ok = False
    print("FAIL: low-power vapor_event nonzero")
if float(np.max(np.abs(final_low["vapor_thickness"]))) > 0.0:
    ok = False
    print("FAIL: low-power vapor_thickness nonzero")
if float(np.max(np.abs(final_low["RoP_vap"]))) > 0.0:
    ok = False
    print("FAIL: low-power RoP_vap nonzero")

# Unified RoP must equal RoP_spall on detached cells, zero elsewhere.
if not np.all(np.isclose(final_low["RoP"][det_low],
                         final_low["RoP_spall"][det_low], atol=1.0e-12)):
    ok = False
    print("FAIL: low-power unified RoP != RoP_spall on detached cells")
if float(np.max(np.abs(final_low["RoP"][non_low]))) > 0.0:
    ok = False
    print("FAIL: low-power unified RoP nonzero outside detached cells")

print(f"low-power detached cells: {int(det_low.sum())}; "
      f"RoP_spall(det) = {float(final_low['RoP_spall'][det_low].mean()):.4f}, "
      f"RoP(det) = {float(final_low['RoP'][det_low].mean()):.4f}")

# --------------------------------------------------------------- high-power
files_high = plotfiles(OUT_HIGH)
if not files_high:
    print("FAIL: no plotfiles in", OUT_HIGH)
    sys.exit(1)
final_high = load_plot(files_high[-1], FIELDS)

if not np.array_equal(final_high["removed"], expected_removed):
    ok = False
    print("FAIL: high-power removed mask differs from expected top-2 layer")

det_hi = expected_removed > 0.5
non_hi = ~det_hi
if not np.all(final_high["regime"][det_hi] == 2.0):
    ok = False
    print("FAIL: high-power regime != 2 on every detached cell")
if float(np.max(np.abs(final_high["regime"][non_hi]))) > 0.0:
    ok = False
    print("FAIL: high-power regime nonzero outside detached cells")

if float(np.max(np.abs(final_high["spall_event"]))) > 0.0:
    ok = False
    print("FAIL: high-power spall_event nonzero")
if float(np.max(np.abs(final_high["RoP_spall"]))) > 0.0:
    ok = False
    print("FAIL: high-power RoP_spall nonzero")

if not np.all(final_high["vapor_event"][det_hi] == 1.0):
    ok = False
    print("FAIL: high-power vapor_event != 1 on detached cells")

# RoP_vap and h_vap closed-form check on detached cells (5% tolerance).
rop_v_sim = final_high["RoP_vap"][det_hi]
h_v_sim   = final_high["vapor_thickness"][det_hi]
print(f"high-power RoP_vap: simulated mean {rop_v_sim.mean():.6f}, "
      f"expected {ROP_VAP_EXPECTED:.6f}")
print(f"high-power h_vap:   simulated mean {h_v_sim.mean():.6f}, "
      f"expected {H_VAP_EXPECTED:.6f}")
tol_rel = 0.05
if not np.all(np.abs(rop_v_sim - ROP_VAP_EXPECTED)
              <= tol_rel * abs(ROP_VAP_EXPECTED) + 1.0e-12):
    ok = False
    print("FAIL: high-power RoP_vap differs from closed form by > 5%")
if not np.all(np.abs(h_v_sim - H_VAP_EXPECTED)
              <= tol_rel * abs(H_VAP_EXPECTED) + 1.0e-12):
    ok = False
    print("FAIL: high-power h_vap differs from closed form by > 5%")

# Unified RoP must equal RoP_vap on detached cells, zero elsewhere.
if not np.all(np.isclose(final_high["RoP"][det_hi],
                         final_high["RoP_vap"][det_hi], atol=1.0e-12)):
    ok = False
    print("FAIL: high-power unified RoP != RoP_vap on detached cells")
if float(np.max(np.abs(final_high["RoP"][non_hi]))) > 0.0:
    ok = False
    print("FAIL: high-power unified RoP nonzero outside detached cells")

# Detached cells should reset Temp -> T_amb, D -> 0.
if not np.all(np.isclose(final_high["Temp"][det_hi], T_AMB, atol=1.0e-9)):
    ok = False
    print("FAIL: high-power detached cells did not reset Temp to T_amb")
if float(np.max(np.abs(final_high["D"][det_hi]))) > 1.0e-12:
    ok = False
    print("FAIL: high-power detached cells did not reset D")

# Surface mask migrated to k = nz - 3 (the new top after removing 2 layers).
expected_surface = np.zeros_like(final_high["surface"])
expected_surface[:, :, nz - 3] = 1.0
if not np.array_equal(final_high["surface"], expected_surface):
    ok = False
    print("FAIL: high-power surface mask did not migrate to new top row")
if not np.array_equal(final_low["surface"], expected_surface):
    ok = False
    print("FAIL: low-power surface mask did not migrate to new top row")

# Sanity: phi shifted down by h_chosen across the full column.
zc = (np.arange(nz) + 0.5) / nz
phi_init = (1.0 - zc)
phi_init_3d = np.broadcast_to(phi_init[None, None, :], final_low["phi"].shape)
phi_low_err  = float(np.max(np.abs(final_low["phi"]  - (phi_init_3d - H_SPALL))))
phi_high_err = float(np.max(np.abs(final_high["phi"] - (phi_init_3d - H_VAP_EXPECTED))))
print(f"phi shift error (low):  {phi_low_err:.3e}")
print(f"phi shift error (high): {phi_high_err:.3e}")
if phi_low_err  > 1.0e-12: ok = False; print("FAIL: low-power phi shift")
if phi_high_err > 1.0e-3:  ok = False; print("FAIL: high-power phi shift")

# Comparison plot.
try:
    import matplotlib
    matplotlib.use("Agg")
    import matplotlib.pyplot as plt

    rop_spall_low = float(final_low["RoP_spall"][det_low].mean())
    rop_vap_low   = 0.0
    rop_total_low = float(final_low["RoP"][det_low].mean())
    rop_spall_hi  = 0.0
    rop_vap_hi    = float(final_high["RoP_vap"][det_hi].mean())
    rop_total_hi  = float(final_high["RoP"][det_hi].mean())

    expected_low  = [H_SPALL,           0.0,              H_SPALL]
    expected_high = [0.0,               ROP_VAP_EXPECTED, ROP_VAP_EXPECTED]
    sim_low       = [rop_spall_low,     rop_vap_low,      rop_total_low]
    sim_high      = [rop_spall_hi,      rop_vap_hi,       rop_total_hi]

    labels = ["RoP_spall", "RoP_vap", "RoP"]
    x = np.arange(len(labels))
    width = 0.18

    fig, axes = plt.subplots(1, 2, figsize=(9.0, 4.0))
    for ax, sim, exp, title in zip(
        axes,
        [sim_low, sim_high],
        [expected_low, expected_high],
        ["Low-power (spall, regime=1)", "High-power (vapor, regime=2)"],
    ):
        ax.bar(x - width, exp, 2 * width, label="expected", color="0.75")
        ax.bar(x + width, sim, 2 * width, label="simulated", color="C0")
        ax.set_xticks(x)
        ax.set_xticklabels(labels)
        ax.set_ylabel("rate-of-penetration (units/s)")
        ax.set_title(title)
        ax.legend(loc="best")
    fig.tight_layout()
    out_path = os.path.join(OUT_LOW if manual else run_low_outdir, "comparison.png")
    fig.savefig(out_path, dpi=120)
    plt.close(fig)
    print("wrote", out_path)
except Exception as exc:
    print(f"WARN: skipped comparison.png ({exc})")

print()
print("PASS" if ok else "FAIL")
sys.exit(0 if ok else 1)
