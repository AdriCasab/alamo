#!/usr/bin/env python3
# Step 12c: closed-form verification of Sp = K_I/K_Ic(T) on the sp_weibull
# branch. The ALAMO input drives sigma_xx(x,y,z,t) and T_surface(t) directly
# via spallation.sp.prescribed_stress / prescribed_T_surface so the test
# isolates the K_I integrator and K_Ic(T) interpolator from FEM-stress
# noise. The Python reference re-implements the same K_I formula (Tada
# weight via trig substitution) and K_Ic(T) Nasseri 2007 table (scaled by
# 1.05 for Central Aare per revised-model-approach.md s11) and asserts
# agreement within 5% over t in [0, 10] s.
#
# Step 15b: the K_I integrand consumes -sigma_xx (compression-positive).
# The input now prescribes a COMPRESSIVE (negative) tension-positive
# sigma_xx; the Python reference integrates -sigma to match, and the test
# additionally asserts a compressive surface yields Sp > 0 (the s12b sign
# convention the original tensile self-consistent test could not catch).

import glob
import math
import os
import re
import shutil
import subprocess
import sys

import numpy as np
import yt

yt.funcs.mylog.setLevel(40)

ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", "..", ".."))
TEST_DIR = os.path.join(ROOT, "tests", "MMWSpalling", "sp_onset_kant_closed_form")
BIN = os.path.join(ROOT, "bin", "mmwspalling-3d-g++")
INPUT_FILE = os.path.join(TEST_DIR, "input")
OUT_ROOT = os.path.join(TEST_DIR, "output")

# Mirrors the input file. Update both together if the input changes.
A0 = 20.0e-6                # m (deterministic surface flaw length)
KIC_SCALE = 1.05            # Central Aare scaling on Nasseri 2007 (1.5/1.43)
N_SEGMENTS = 128            # composite Simpson segments
T_REF_INIT = 298.15         # K, surface T at t=0
T_HEAT_RATE = 30.0          # K/s
SIGMA_AMP_PA = 50.0e6       # peak |sigma_xx| (Pa); prescribed compressive
SIGMA_TAU_S = 5.0           # saturation time constant (s)
STOP_TIME = 10.0
DT = 0.5
REL_TOL = 0.05              # 5% per the active step
ABS_TOL = 1.0e-6            # guard against div-by-near-zero Sp_closed

# Nasseri 2007 Table 4 (Westerly granite). Temperatures in K.
NASSERI_T_K = np.array([298.15, 523.15, 723.15, 923.15, 1123.15])
NASSERI_KIC_MPA = np.array([1.43, 1.35, 0.98, 0.43, 0.22])


def sigma_xx_input(t):
    # ALAMO-convention tension-positive sigma_xx; the input prescribes a
    # compressive (negative) ramp, matching xx_expr = -50.0e6*(1-exp(-t/5)).
    return -SIGMA_AMP_PA * (1.0 - math.exp(-t / SIGMA_TAU_S))


def T_surface_input(t):
    return T_REF_INIT + T_HEAT_RATE * t


def k_ic_nasseri_pa_sqrtm(T_K):
    """Piecewise-linear K_Ic(T) with endpoint clamping, scaled and in Pa*sqrt(m)."""
    mpa = KIC_SCALE * np.interp(T_K, NASSERI_T_K, NASSERI_KIC_MPA)
    return mpa * 1.0e6


def k_i_closed_form(t):
    """K_I from sigma_xx(z, t) = sigma_xx_input(t) (z-independent).

    Step 15b sign convention: the integrand consumes -sigma_xx, so a
    compressive (negative) sigma_xx gives K_I > 0.
        K_I = 2*sqrt(a/pi) * (-sigma) * integral_0^{pi/2} (1.3 - 0.3 sin(theta)^(5/4)) dtheta
    """
    sigma = -sigma_xx_input(t)
    # composite Simpson on theta in [0, pi/2]; matches the ALAMO integrator.
    n = N_SEGMENTS
    if n % 2 != 0:
        n += 1
    h = (0.5 * math.pi) / n
    acc = 0.0
    for k in range(n + 1):
        theta = h * k
        xi = math.sin(theta)
        g_xi = 1.3 - 0.3 * (xi ** 1.25)
        if k == 0 or k == n:
            w = 1.0
        elif k % 2 == 1:
            w = 4.0
        else:
            w = 2.0
        acc += w * sigma * g_xi
    acc *= h / 3.0
    return 2.0 * math.sqrt(A0 / math.pi) * acc


def sp_closed_form(t):
    return k_i_closed_form(t) / k_ic_nasseri_pa_sqrtm(T_surface_input(t))


def plotfiles(outdir):
    pat = re.compile(r"(\d+)cell$")
    cands = []
    for path in glob.glob(os.path.join(outdir, "*cell")):
        m = pat.search(os.path.basename(path))
        if m:
            cands.append((int(m.group(1)), path))
    cands.sort()
    return cands


def run_alamo():
    if not os.path.exists(BIN):
        print(f"FAIL: missing binary {BIN}; build first")
        sys.exit(1)
    if os.path.isdir(OUT_ROOT):
        shutil.rmtree(OUT_ROOT)
    cmd = [
        "mpirun", "--oversubscribe", "--bind-to", "none", "-np", "4",
        BIN, INPUT_FILE,
    ]
    print("Running:", " ".join(cmd))
    env = os.environ.copy()
    env.setdefault("OMPI_MCA_btl", "self,vader,tcp")
    res = subprocess.run(cmd, cwd=ROOT, env=env)
    if res.returncode != 0:
        print(f"FAIL: ALAMO run exited with {res.returncode}")
        sys.exit(res.returncode)


def sp_at_top(path):
    """Return (t, mean_Sp_top, max_abs_dev_top) for a cell plotfile.

    Sp_field is written into the topmost cell of each (i,j) column; mean
    and max-abs-deviation across that slab should agree because sigma_xx
    is position-independent in this test.
    """
    ds = yt.load(path)
    t = float(ds.current_time)
    ad = ds.all_data()
    z = np.asarray(ad["z"].to_value())
    sp = np.asarray(ad["Sp_field"].to_value())
    if not np.all(np.isfinite(sp)):
        raise RuntimeError(f"{path}: non-finite Sp_field values")
    z_top_cell = z.max()
    mask = np.isclose(z, z_top_cell, atol=1.0e-9)
    if not np.any(mask):
        raise RuntimeError(f"{path}: no top z-cell samples found")
    sp_top = sp[mask]
    if sp_top.size == 0:
        raise RuntimeError(f"{path}: empty top z-slab")
    sp_mean = float(np.mean(sp_top))
    sp_dev  = float(np.max(np.abs(sp_top - sp_mean)))
    return t, sp_mean, sp_dev


def main():
    run_alamo()

    pf = plotfiles(OUT_ROOT)
    if not pf:
        print(f"FAIL: no cell plotfiles in {OUT_ROOT}")
        sys.exit(1)

    # Plot timing: ALAMO's Advance(time, dt) takes `time` = start-of-step,
    # and the Sp evaluator runs after the mechanics solve which used
    # temp_mf at start-of-step. So the Sp_field stored in the plotfile
    # named `<n>cell` (with current_time = n*dt for fixed timestep) was
    # actually computed at t_eval = (n-1)*dt. Compare against the
    # closed-form at t_eval for n >= 1; the initial plotfile (step 0,
    # t_eval == 0) has Sp_field set to its allocation default of 0.
    print(
        f"{'step':>6} {'t_plot':>8} {'t_eval':>8} {'Sp_alamo':>12} "
        f"{'Sp_closed':>12} {'rel_err':>10} {'col_disp':>10}"
    )
    failures = 0
    sign_checked = False
    for step, path in pf:
        t, sp_alamo, sp_dev = sp_at_top(path)
        t_eval = max(0.0, t - DT) if step > 0 else 0.0
        sp_ref = sp_closed_form(t_eval)
        denom = max(abs(sp_ref), ABS_TOL)
        rel = abs(sp_alamo - sp_ref) / denom
        col_disp = sp_dev / denom
        flag = "" if rel < REL_TOL and col_disp < REL_TOL else "  <-- FAIL"
        print(
            f"{step:>6d} {t:>8.3f} {t_eval:>8.3f} {sp_alamo:>12.5e} "
            f"{sp_ref:>12.5e} {rel:>10.3e} {col_disp:>10.3e}{flag}"
        )
        if rel >= REL_TOL or col_disp >= REL_TOL:
            failures += 1
        # Step 15b sign convention: once sigma_xx has ramped up (t_eval > 0),
        # the compressive prescribed stress must give a strictly positive Sp.
        if t_eval > 0.0:
            sign_checked = True
            if not (sp_alamo > 0.0 and sp_ref > 0.0):
                print(f"FAIL: sign convention -- compressive sigma_xx must give "
                      f"Sp > 0, got Sp_alamo={sp_alamo:.5e}, Sp_closed={sp_ref:.5e} "
                      f"at t_eval={t_eval:.3f}")
                failures += 1

    if not sign_checked:
        print("FAIL: no plotfile with t_eval > 0 -- sign convention unchecked")
        sys.exit(1)
    if failures > 0:
        print(f"FAIL: {failures} check(s) failed")
        sys.exit(1)
    print(f"PASS: {len(pf)} plotfiles, Sp_alamo matches closed-form within "
          f"+/-{REL_TOL*100:.1f}% over t in [0, {STOP_TIME}] s; "
          f"compressive sigma_xx gives Sp > 0 (s12b sign convention).")


if __name__ == "__main__":
    main()
