#!/usr/bin/env python3
# Step 16c — Rossi 2018 damage-profile validation via the per-step h_col
# event CSV log.
#
# Step 16b's cell-centred `crack_event_count` field could not resolve
# Rossi's sub-cell 100-200 µm peak at the working mesh (dz = 1.5625 mm) —
# all events landed in the top cell. Step 16c switches the observable:
# `UpdateRemovalAfterCohesive` (under sp_weibull + spall.enabled) emits
# one CSV row per column on the FIRST timestep that column's cluster_id
# transitions to > 0 (the freeze guard reuses cec(i, j, k_top) > 0.5),
# recording (time, col_i, col_j, a_f, h_col, is_gb_at_top,
# Sp_field_at_top). h_col is bisection-refined to dz/256 ≈ 6 µm.
# Histogramming h_col across all (column × first-firing) events into
# 94 µm bins gives Rossi's depth-distribution observable directly.
#
# Three Rossi bands (long plan §16a, 16c packet):
#   R1 BINDING — three-conjunction shape check:
#     (1) peak bin centre in [100, 200] µm,
#     (2) NO bin deeper than the peak has density > peak (no secondary
#         lobes — guards against unimodal-but-wrong-tail histograms),
#     (3) density at bin nearest 520 µm is <= 25% of peak (Rossi falloff).
#     ALL THREE must hold for R1 PASS; sub-criteria reported individually.
#   R2 WARNING — peak crack density in [3.0, 11.0] mm⁻² (Rossi 4.4-7.6
#     ± 30%). Reported, not gated.
#   R3 INFORMATIONAL — ρ_B/ρ_I (24:1 in 16b under late-ramp σ_xx skew).
#     Reported, NOT gated. Time-binning relocates events along the depth
#     axis but doesn't add IG events; path to 5:1 is higher peak σ_xx,
#     re-examined a0_ig, or finer mesh.
#
# Step 16 P1-P4 mechanics gates retained as `[diag]` — must still PASS.
#
# Bisection-tolerance vs bin-width invariant (16c packet): bisection 8
# iter → dz/256 ≈ 6 µm tolerance; histogram bin width 94 µm ≈ 15× the
# tolerance. Tolerance is well below bin width so sub-bin h_col position
# is determined by the K_I = K_Ic crossing physics, not by bisection
# convergence error. Keep `N_BISECT = 8` and `bin_width = 94 µm`
# together — any future change to one must reassess against the other.

import glob
import math
import os
import re
import shutil
import subprocess
import sys

import numpy as np
import yt

yt.funcs.mylog.setLevel(40)

ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", "..", ".."))
TEST_DIR = os.path.join(ROOT, "tests", "MMWSpalling", "sp_rossi_damage_profile")
BIN = os.path.join(ROOT, "bin", "mmwspalling-3d-g++")
INPUT_PATH = os.path.join(TEST_DIR, "input")
OUTDIR = os.path.join(TEST_DIR, "output", "rossi")
CSV_PATH = os.path.join(TEST_DIR, "output", "rossi_h_col_events.csv")

# Geometry: full-face heating under Kant-style lateral roller box (see
# input file). A_PATCH_MM2 is the heated face area (Step 16c packet:
# 50 × 50 = 2500 mm²).
PROB_HI_Z   = 0.050
FACE_X_MM   = 50.0
FACE_Y_MM   = 50.0
A_PATCH_MM2 = FACE_X_MM * FACE_Y_MM   # = 2500 mm^2

# Rossi 2018 reference (long-plan §16a).
PEAK_DEPTH_LO_UM = 100.0
PEAK_DEPTH_HI_UM = 200.0
BASELINE_DEPTH_UM = 520.0
ROSSI_PEAK_DENSITY_MIN_MM = 3.0   # 4.4 / 1.3 (R2 warning band)
ROSSI_PEAK_DENSITY_MAX_MM = 11.0  # 7.6 * 1.3
RHO_B_OVER_I_LO, RHO_B_OVER_I_HI = 4.0, 7.5  # R3 reference, NOT gated

# 94 µm bins from 0 to 1.5 mm (slightly past dz so any bisection-found
# crossings just inside the top cell show up).
BIN_EDGES_UM = np.arange(0.0, 1500.0 + 94.0, 94.0)
BIN_CENTRES_UM = 0.5 * (BIN_EDGES_UM[:-1] + BIN_EDGES_UM[1:])

# R1 falloff threshold.
BASELINE_FRAC = 0.25

# Step 16 mechanics diagnostic-only gates.
GB_FRACTION_DIAG_MIN = 0.50
MAX_H_SPALL_MM       = 10.0


def plotfiles(outdir):
    pat = re.compile(r"(\d+)cell$")
    cands = []
    for path in glob.glob(os.path.join(outdir, "*cell")):
        m = pat.search(os.path.basename(path))
        if m:
            cands.append((int(m.group(1)), path))
    cands.sort()
    return [p for _, p in cands]


def run_alamo():
    if not os.path.exists(BIN):
        print(f"FAIL: missing binary {BIN}; build first")
        sys.exit(1)
    if os.path.isdir(OUTDIR):
        shutil.rmtree(OUTDIR)
    if os.path.exists(CSV_PATH):
        os.remove(CSV_PATH)
    cmd = ["mpirun", "--oversubscribe", "--bind-to", "none", "-np", "4",
           BIN, INPUT_PATH]
    print("Running:", " ".join(cmd))
    env = os.environ.copy()
    env.setdefault("OMPI_MCA_btl", "self,vader,tcp")
    res = subprocess.run(cmd, cwd=ROOT, env=env)
    if res.returncode != 0:
        print(f"FAIL: ALAMO run for Rossi exited with {res.returncode}")
        sys.exit(res.returncode)


def np_(arr):
    return np.asarray(arr.to_value() if hasattr(arr, "to_value") else arr)


def load_csv():
    """Read the h_col first-firing event CSV. Returns dict of arrays."""
    if not os.path.exists(CSV_PATH):
        return None
    rows = []
    with open(CSV_PATH, "r") as f:
        header = f.readline().strip().split(",")
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split(",")
            rows.append([float(x) for x in parts])
    if not rows:
        return {
            "time":  np.zeros(0),
            "col_i": np.zeros(0, dtype=int),
            "col_j": np.zeros(0, dtype=int),
            "a_f":   np.zeros(0),
            "h_col": np.zeros(0),
            "is_gb": np.zeros(0, dtype=bool),
            "sp":    np.zeros(0),
        }
    arr = np.array(rows)
    return {
        "time":  arr[:, 0],
        "col_i": arr[:, 1].astype(int),
        "col_j": arr[:, 2].astype(int),
        "a_f":   arr[:, 3],
        "h_col": arr[:, 4],
        "is_gb": arr[:, 5].astype(bool),
        "sp":    arr[:, 6],
    }


def load_final_plotfile_diagnostics(path):
    """Read final plotfile for Step 16 P1-P4 diagnostic gates."""
    ds = yt.load(path)
    ad = ds.all_data()
    x = np_(ad["x"]); y = np_(ad["y"]); z = np_(ad["z"])
    top = np.isclose(z, z.max(), atol=1.0e-9)
    out = {
        "t":      float(ds.current_time),
        "n_top":  int(np.count_nonzero(top)),
        "hsf":    np_(ad["h_spall_field"])[top],
        "is_gb":  np_(ad["is_grain_boundary"])[top].astype(bool),
        "removed_total": float(np.sum(np_(ad["removed"]))),
    }
    return out


def main():
    manual = len(sys.argv) > 1
    if not manual:
        run_alamo()

    print()
    print("=" * 70)
    print("Step 16c Rossi 2018 damage-profile validation (h_col CSV histogram)")

    csv = load_csv()
    if csv is None:
        print(f"FAIL: no CSV found at {CSV_PATH}")
        return 1

    n_events = len(csv["h_col"])
    print(f"loaded {n_events} first-firing events from "
          f"{os.path.basename(CSV_PATH)}")
    if n_events == 0:
        print("FAIL: empty CSV — no columns crossed K_I >= K_Ic during the "
              "run. Check spallation.model = sp_weibull, "
              "spall.enabled = 1, and stop_time")
        return 1

    h_um = csv["h_col"] * 1.0e6
    print(f"\nh_col stats over first-firing events:")
    print(f"  min    = {h_um.min():9.3f} µm")
    print(f"  mean   = {h_um.mean():9.3f} µm")
    print(f"  median = {np.median(h_um):9.3f} µm")
    print(f"  max    = {h_um.max():9.3f} µm")
    print(f"  std    = {h_um.std():9.3f} µm")

    # Time distribution.
    print(f"\nfirst-firing time stats:")
    print(f"  min    = {csv['time'].min():7.2f} s")
    print(f"  mean   = {csv['time'].mean():7.2f} s")
    print(f"  median = {np.median(csv['time']):7.2f} s")
    print(f"  max    = {csv['time'].max():7.2f} s")

    # Histogram.
    counts, _ = np.histogram(h_um, bins=BIN_EDGES_UM)
    density = counts / A_PATCH_MM2 if A_PATCH_MM2 > 0 else counts * 0.0
    print()
    print("Depth profile (94 µm bins, h_col from CSV first-firing events):")
    print(f"  {'bin (µm)':>15s}  {'counts':>10s}  {'density (mm^-2)':>16s}")
    for k in range(len(BIN_CENTRES_UM)):
        if counts[k] > 0:
            lo = BIN_EDGES_UM[k]
            hi = BIN_EDGES_UM[k + 1]
            print(f"  [{lo:>6.1f}, {hi:>6.1f}]  {int(counts[k]):>10d}  "
                  f"{density[k]:>16.4f}")

    if counts.sum() == 0:
        print("FAIL: all events outside the 0-1.5 mm histogram window")
        return 1

    peak_idx = int(np.argmax(counts))
    peak_centre = float(BIN_CENTRES_UM[peak_idx])
    peak_lo = float(BIN_EDGES_UM[peak_idx])
    peak_hi = float(BIN_EDGES_UM[peak_idx + 1])
    peak_density = float(density[peak_idx])
    baseline_idx = int(np.argmin(np.abs(BIN_CENTRES_UM - BASELINE_DEPTH_UM)))
    baseline_density = float(density[baseline_idx])
    print(f"\npeak bin: [{peak_lo:.0f}, {peak_hi:.0f}] µm "
          f"(centre {peak_centre:.0f} µm), density = "
          f"{peak_density:.4f} mm^-2")
    print(f"baseline bin (nearest {BASELINE_DEPTH_UM:.0f} µm, centre "
          f"{BIN_CENTRES_UM[baseline_idx]:.0f} µm): density = "
          f"{baseline_density:.4f} mm^-2")

    ok = True

    # ---- R1 (binding) — three-conjunction shape check ----------------
    print()
    print("[R1] three-conjunction shape check (BINDING)")
    # (1) peak bin centre in [100, 200] µm
    peak_in_band = (peak_centre >= PEAK_DEPTH_LO_UM and
                    peak_centre <= PEAK_DEPTH_HI_UM)
    # (2) no deeper bin has density > peak density (no secondary lobes)
    deeper_lobe_idx = None
    deeper_lobe_dens = None
    for k in range(peak_idx + 1, len(BIN_CENTRES_UM)):
        if density[k] > peak_density:
            deeper_lobe_idx = k
            deeper_lobe_dens = float(density[k])
            break
    no_deeper_lobe = (deeper_lobe_idx is None)
    # (3) density at bin nearest 520 µm <= 25% of peak
    falloff_ratio = (baseline_density / peak_density
                     if peak_density > 0 else float("inf"))
    falloff_ok = (falloff_ratio <= BASELINE_FRAC)

    print(f"  (1) peak in [{PEAK_DEPTH_LO_UM:.0f}, "
          f"{PEAK_DEPTH_HI_UM:.0f}] µm: peak at {peak_centre:.0f} µm "
          f"— {'PASS' if peak_in_band else 'FAIL'}")
    print(f"  (2) no deeper bin > peak density: ", end="")
    if no_deeper_lobe:
        print("PASS")
    else:
        print(f"FAIL — bin centred at "
              f"{BIN_CENTRES_UM[deeper_lobe_idx]:.0f} µm has density "
              f"{deeper_lobe_dens:.4f} mm⁻² > peak "
              f"{peak_density:.4f} mm⁻²")
    print(f"  (3) baseline @ {BASELINE_DEPTH_UM:.0f} µm density / peak "
          f"= {falloff_ratio:.4f} <= {BASELINE_FRAC}: "
          f"{'PASS' if falloff_ok else 'FAIL'}")

    if not (peak_in_band and no_deeper_lobe and falloff_ok):
        ok = False
        fail_subs = []
        if not peak_in_band:    fail_subs.append("(1) peak depth")
        if not no_deeper_lobe:  fail_subs.append("(2) secondary lobe")
        if not falloff_ok:      fail_subs.append("(3) baseline falloff")
        print(f"FAIL (R1): sub-criteria {', '.join(fail_subs)}. See the "
              f"'Expected outcomes' branch in ACTIVE_STEP.md for the "
              f"diagnosis path matching this sub-criterion combination")

    # ---- R2 (warning, NOT a FAIL) ------------------------------------
    print()
    print("[R2] peak density magnitude (warning-only per long plan §16a)")
    density_in_band = (ROSSI_PEAK_DENSITY_MIN_MM <= peak_density <=
                       ROSSI_PEAK_DENSITY_MAX_MM)
    print(f"  peak density {peak_density:.4f} mm⁻² in "
          f"[{ROSSI_PEAK_DENSITY_MIN_MM:.1f}, "
          f"{ROSSI_PEAK_DENSITY_MAX_MM:.1f}] mm⁻²: "
          f"{'PASS' if density_in_band else 'WARN'}")
    if not density_in_band:
        print(f"WARN (R2): peak density {peak_density:.4f} mm⁻² outside "
              f"Rossi's 4.4-7.6 mm⁻² ± 30% bracket. Magnitude is "
              f"secondary per long plan §16a; depth-profile shape (R1) "
              f"is the binding metric.")

    # ---- R3 (informational, NOT gated) -------------------------------
    print()
    print("[R3] GB/IG partition (INFORMATIONAL, NOT gated in 16c)")
    in_zone = (h_um >= PEAK_DEPTH_LO_UM) & (h_um <= BASELINE_DEPTH_UM)
    is_gb = csv["is_gb"]
    n_zone_gb = int(np.count_nonzero(in_zone & is_gb))
    n_zone_ig = int(np.count_nonzero(in_zone & ~is_gb))
    if n_zone_ig == 0:
        ratio = float("inf") if n_zone_gb > 0 else float("nan")
        print(f"  zone events: GB = {n_zone_gb}, IG = 0; "
              f"ρ_B/ρ_I = inf (no IG events in damage zone)")
    else:
        ratio = n_zone_gb / n_zone_ig
        print(f"  zone events: GB = {n_zone_gb}, IG = {n_zone_ig}; "
              f"ρ_B/ρ_I = {ratio:.2f} "
              f"(Rossi reference: ~5, Step 16b found 24:1)")
    n_all_gb = int(np.count_nonzero(is_gb))
    n_all_ig = int(np.count_nonzero(~is_gb))
    print(f"  all-events partition: GB = {n_all_gb}, IG = {n_all_ig} "
          f"({100.0 * n_all_gb / max(n_all_gb + n_all_ig, 1):.1f}% GB)")
    print(f"  NOTE: 16c does not gate on R3; the 24:1 vs 5:1 gap is a "
          f"separate finding (see ACTIVE_STEP.md / ROADMAP Known Notes — "
          f"path to 5:1 is higher peak σ_xx, re-examined a0_ig, or "
          f"finer mesh)")

    # ---- Step 16 mechanics diagnostic-only (P1-P4) ------------------
    print()
    print("[diag] Step 16 mechanics gates (informational, retained)")
    files = plotfiles(OUTDIR)
    if files:
        last = load_final_plotfile_diagnostics(files[-1])
        n_hsf = int(np.count_nonzero(last["hsf"] > 0.0))
        print(f"  P1 h_spall_field > 0 on top slab: "
              f"{n_hsf}/{last['n_top']} columns "
              f"({'PASS' if n_hsf > 0 else 'FAIL'})")
        print(f"  P2 cells removed: {int(last['removed_total'])} "
              f"({'PASS' if last['removed_total'] > 0 else 'FAIL'})")
        fired = last["hsf"] > 0.0
        if fired.any():
            n_top_gb = int(np.count_nonzero(fired & last["is_gb"]))
            gb_frac = n_top_gb / int(fired.sum())
            print(f"  P3 top-slab GB fraction (firing columns): "
                  f"{gb_frac:.1%} "
                  f"({'PASS' if gb_frac >= GB_FRACTION_DIAG_MIN else 'FAIL'})")
        else:
            print(f"  P3 top-slab GB fraction: no firings")
        h_max_mm = float(last["hsf"].max()) * 1.0e3
        print(f"  P4 max h_spall_field: {h_max_mm:.4f} mm "
              f"(<= {MAX_H_SPALL_MM:.1f} mm: "
              f"{'PASS' if h_max_mm <= MAX_H_SPALL_MM else 'FAIL'})")
    else:
        print("  P1-P4: no plotfiles found")

    plot_results(csv, counts, density, peak_idx, baseline_idx)

    print()
    print("=" * 70)
    print("PASS" if ok else "FAIL")
    return 0 if ok else 1


def plot_results(csv, counts, density, peak_idx, baseline_idx):
    try:
        import matplotlib
        matplotlib.use("Agg")
        import matplotlib.pyplot as plt
    except ImportError:
        print("(matplotlib not installed - skipping PNG plot)")
        return

    fig, axes = plt.subplots(1, 2, figsize=(11.0, 4.4))

    # Panel 1: ALAMO depth profile vs Rossi reference bands.
    ax = axes[0]
    width = np.diff(BIN_EDGES_UM)
    ax.bar(BIN_CENTRES_UM, density, width=width * 0.85, color="C0",
           label=f"ALAMO h_col CSV ({int(counts.sum())} events)")
    ax.bar(BIN_CENTRES_UM[peak_idx], density[peak_idx],
           width=width[peak_idx] * 0.85, fill=False,
           edgecolor="red", linewidth=2.0,
           label=f"peak bin (centre {BIN_CENTRES_UM[peak_idx]:.0f} µm)")
    ax.axvspan(PEAK_DEPTH_LO_UM, PEAK_DEPTH_HI_UM, color="C2", alpha=0.20,
               label="Rossi peak band 100-200 µm")
    ax.axhspan(ROSSI_PEAK_DENSITY_MIN_MM, ROSSI_PEAK_DENSITY_MAX_MM,
               color="0.6", alpha=0.20,
               label=f"Rossi density 4.4-7.6 mm⁻² (R2 warn)")
    ax.axvline(BASELINE_DEPTH_UM, color="C3", linestyle="--",
               label="Rossi baseline @ 520 µm")
    ax.set_xlabel("h_col [µm] (sub-cell, bisection-refined)")
    ax.set_ylabel("crack density [mm⁻²]")
    ax.set_title("Rossi depth profile (94 µm bins, first-firing events)")
    ax.legend(fontsize=7, loc="upper right")

    # Panel 2: GB-vs-IG event counts per depth bin.
    ax = axes[1]
    h_um = csv["h_col"] * 1.0e6
    is_gb = csv["is_gb"]
    gb_counts, _ = np.histogram(h_um[is_gb], bins=BIN_EDGES_UM)
    ig_counts, _ = np.histogram(h_um[~is_gb], bins=BIN_EDGES_UM)
    ax.bar(BIN_CENTRES_UM - width * 0.20, gb_counts, width=width * 0.4,
           color="C0", label=f"GB (n={int(gb_counts.sum())})")
    ax.bar(BIN_CENTRES_UM + width * 0.20, ig_counts, width=width * 0.4,
           color="C1", label=f"IG (n={int(ig_counts.sum())})")
    ax.axvspan(PEAK_DEPTH_LO_UM, BASELINE_DEPTH_UM, color="C2", alpha=0.10,
               label="damage zone (R3 informational)")
    ax.set_xlabel("h_col [µm]")
    ax.set_ylabel("event count per bin")
    ax.set_title("GB-vs-IG partition (R3 informational, not gated)")
    ax.legend(fontsize=8)

    fig.tight_layout()
    out_root = os.path.dirname(OUTDIR)
    os.makedirs(out_root, exist_ok=True)
    out_png = os.path.join(out_root, "comparison.png")
    fig.savefig(out_png, dpi=140)
    print(f"\nwrote {out_png}")


if __name__ == "__main__":
    sys.exit(main())
