#!/usr/bin/env python3
# Step 8b: Hu breakage-probability indicator validation.
#
# This regression post-processes homogeneous Hu thermoelastic node plotfiles and
# computes Hu's indicator f_b = sigma_v / sigma_s.  It intentionally leaves the
# Step 8 Drucker-Prager damage model disabled: this is a stress-indicator check,
# not a damage/spall-removal validation.
#
# Usage:
#   python3 tests/MMWSpalling/hu_breakage_index/test
#   python3 tests/MMWSpalling/hu_breakage_index/test <output_root>

import glob
import math
import os
import sys

import numpy as np
import yt


ROOT = os.path.dirname(os.path.abspath(__file__))
OUTPUT_ROOT = sys.argv[1] if len(sys.argv) > 1 else os.path.join(ROOT, "output")

SIGMA_S_GRANITE = 103.87e6
SIGMA_S_SANDSTONE = 80.11e6

HU_FB_GRANITE_ONSET = 0.91
HU_FB_SANDSTONE_ONSET = 0.82
FB_ABS_TOL = 0.10

HU_L5_CENTER_MARGIN_PCT = 19.69

# Hu reports f_b < 0.1 along L6 deeper than ~14 mm under his bottom roller.
# Step 7b documented that a pure-roller elastic solve loses MLMG convergence
# in this setup, so Step 7b/7d/8b run with a bottom clamp instead. The clamp
# preserves more compressive stress at depth than Hu's roller, which inflates
# the L6 deep tail proportionally to the now-correct surface eigenstrain. The
# Hu surface targets pass cleanly; the deep threshold is held at 0.25 as a
# qualitative localization check with the bottom-clamp caveat from Step 7b.
L6_DEEP_FB_TOL = 0.25

PATCH_X0 = 0.05
PATCH_Y0 = 0.05
PATCH_RADIUS = 0.015
Z_TOP = 0.10

CASES = {
    "granite37": {
        "label": "Granite 2 at 37 s",
        "outdir": os.path.join(OUTPUT_ROOT, "granite2_37"),
        "target_t": 37.0,
        "target_step": 185,
        "sigma_s": SIGMA_S_GRANITE,
        "hu_fb": HU_FB_GRANITE_ONSET,
    },
    "sandstone37": {
        "label": "Sandstone 2 at 37 s",
        "outdir": os.path.join(OUTPUT_ROOT, "sandstone2_37"),
        "target_t": 37.0,
        "target_step": 185,
        "sigma_s": SIGMA_S_SANDSTONE,
        "hu_fb": None,
    },
    "sandstone89": {
        "label": "Sandstone 2 at 89 s",
        "outdir": os.path.join(OUTPUT_ROOT, "sandstone2_89"),
        "target_t": 89.0,
        "target_step": 445,
        "sigma_s": SIGMA_S_SANDSTONE,
        "hu_fb": HU_FB_SANDSTONE_ONSET,
    },
}


def latest_plotfile(outdir, target_t, suffix="node", target_step=None):
    if target_step is not None:
        exact = os.path.join(outdir, f"{target_step:05d}{suffix}")
        if os.path.isdir(exact):
            ds = yt.load(exact)
            return float(ds.current_time), ds, exact

    plotfiles = sorted(glob.glob(os.path.join(outdir, f"*{suffix}")))
    if not plotfiles:
        raise RuntimeError(f"no *{suffix} plotfiles in {outdir}")

    best = None
    best_dt = math.inf
    for path in plotfiles:
        ds = yt.load(path)
        t = float(ds.current_time)
        dt = abs(t - target_t)
        if dt < best_dt:
            best = (t, ds, path)
            best_dt = dt
    return best


def stress_field_names(ds):
    fields = {f[1] for f in ds.field_list}
    candidates = [
        ("stress_xx", "stress_yy", "stress_zz",
         "stress_xy", "stress_yz", "stress_zx"),
        ("stress_xx", "stress_yy", "stress_zz",
         "stress_xy", "stress_yz", "stress_xz"),
        ("stress11", "stress22", "stress33",
         "stress12", "stress23", "stress13"),
    ]
    for names in candidates:
        if all(name in fields for name in names):
            return names
    raise RuntimeError(
        "could not find stress tensor fields; available stress-like fields are "
        f"{sorted(f for f in fields if 'stress' in f)}"
    )


def vm_from_components(sxx, syy, szz, sxy, syz, szx):
    return np.sqrt(
        0.5 * ((sxx - syy) ** 2 + (syy - szz) ** 2 + (szz - sxx) ** 2)
        + 3.0 * (sxy ** 2 + syz ** 2 + szx ** 2)
    )


def load_fb_case(case):
    t, ds, path = latest_plotfile(
        case["outdir"], case["target_t"], "node", case.get("target_step")
    )
    names = stress_field_names(ds)
    ad = ds.all_data()
    comps = [ad[name].to_value() for name in names]
    for name, values in zip(names, comps):
        if not np.all(np.isfinite(values)):
            raise RuntimeError(f"{case['label']} has non-finite stress in {name}")

    vm = vm_from_components(*comps)
    fb = vm / case["sigma_s"]
    if not np.all(np.isfinite(fb)):
        raise RuntimeError(f"{case['label']} produced non-finite f_b")

    data = {
        "label": case["label"],
        "target_t": case["target_t"],
        "time": t,
        "path": path,
        "ds": ds,
        "x": ad["x"].to_value(),
        "y": ad["y"].to_value(),
        "z": ad["z"].to_value(),
        "vm": vm,
        "fb": fb,
        "sigma_s": case["sigma_s"],
        "hu_fb": case["hu_fb"],
    }
    xs, ys, fb_top = extrapolated_surface(data, z_target=Z_TOP, n_points=3)
    data["x_top"] = xs
    data["y_top"] = ys
    data["fb_top"] = fb_top
    return data


def extrapolated_surface(data, z_target=0.10, n_points=3):
    """Per (x, y) column quadratic extrapolation of f_b to z_target.

    AMReX node plotfiles store stress at cell centres on each refinement
    level, so the highest sampled z plane sits half a cell below z=0.10
    on the coarsest level (and a quarter cell below on a refined level).
    This routine groups points by (x, y) and fits a quadratic through the
    top n_points sampled z values in that column, then evaluates the fit
    at z_target. Columns with fewer than 2 samples are skipped; columns
    with exactly 2 samples fall back to a linear fit.
    """
    x = data["x"]
    y = data["y"]
    z = data["z"]
    fb = data["fb"]
    keys = np.stack([np.round(x, 7), np.round(y, 7)], axis=1)
    columns = {}
    for i in range(len(x)):
        key = (float(keys[i, 0]), float(keys[i, 1]))
        columns.setdefault(key, []).append((float(z[i]), float(fb[i])))

    xs = []
    ys = []
    fbs = []
    for (xq, yq), col in columns.items():
        col.sort(key=lambda t: t[0])
        # Deduplicate identical z values produced by overlapping AMR levels.
        zlist = []
        flist = []
        for zi, fi in col:
            if zlist and abs(zi - zlist[-1]) <= 1.0e-12:
                continue
            zlist.append(zi)
            flist.append(fi)
        n = min(n_points, len(zlist))
        if n < 2:
            continue
        zs = np.array(zlist[-n:])
        fs = np.array(flist[-n:])
        deg = 2 if n >= 3 else 1
        p = np.polyfit(zs, fs, deg)
        xs.append(xq)
        ys.append(yq)
        fbs.append(float(np.polyval(p, z_target)))

    return np.array(xs), np.array(ys), np.array(fbs)


def nearest_idx(data, xq, yq, zq):
    d2 = (
        (data["x"] - xq) ** 2
        + (data["y"] - yq) ** 2
        + (data["z"] - zq) ** 2
    )
    return int(np.argmin(d2))


def top_mask(data):
    z = data["z"]
    zmax = float(np.max(z))
    return np.abs(z - zmax) <= 1.0e-8


def heated_top_mask(data):
    mask = top_mask(data)
    r2 = (data["x"] - PATCH_X0) ** 2 + (data["y"] - PATCH_Y0) ** 2
    return mask & (r2 <= PATCH_RADIUS ** 2 + 1.0e-14)


def extrap_top_mask_heated(data):
    r2 = (data["x_top"] - PATCH_X0) ** 2 + (data["y_top"] - PATCH_Y0) ** 2
    return r2 <= PATCH_RADIUS ** 2 + 1.0e-14


def max_fb_extrap(data, mask=None):
    fb = data["fb_top"]
    if mask is None:
        mask = np.ones_like(fb, dtype=bool)
    if not np.any(mask):
        raise RuntimeError(f"{data['label']} has empty extrapolated mask")
    idx_local = int(np.argmax(fb[mask]))
    idx = int(np.flatnonzero(mask)[idx_local])
    return float(fb[idx]), idx


def center_surface_fb_extrap(data):
    d2 = (data["x_top"] - PATCH_X0) ** 2 + (data["y_top"] - PATCH_Y0) ** 2
    idx = int(np.argmin(d2))
    return float(data["fb_top"][idx]), idx


def surface_line_profile_extrap(data):
    y = data["y_top"]
    x = data["x_top"]
    fb = data["fb_top"]
    # Pick the y-row closest to PATCH_Y0.
    yu = np.unique(np.round(y, 8))
    y_pick = yu[np.argmin(np.abs(yu - PATCH_Y0))]
    mask = np.abs(y - y_pick) <= 1.0e-8
    order = np.argsort(x[mask])
    return x[mask][order], fb[mask][order]


def max_fb(data, mask):
    if not np.any(mask):
        raise RuntimeError(f"{data['label']} has empty mask for f_b maximum")
    idx_local = int(np.argmax(data["fb"][mask]))
    global_indices = np.flatnonzero(mask)
    idx = int(global_indices[idx_local])
    return float(data["fb"][idx]), idx


def center_surface_fb(data):
    idx = nearest_idx(data, PATCH_X0, PATCH_Y0, Z_TOP)
    return float(data["fb"][idx]), idx


def centerline_profile(data):
    x = data["x"]
    y = data["y"]
    z = data["z"]
    # Node plotfiles include the centre coordinates exactly for the 40^3 Hu
    # mesh. Use a tolerance wide enough for yt roundoff, narrow enough to avoid
    # neighbouring lines.
    mask = (np.abs(x - PATCH_X0) <= 1.0e-8) & (np.abs(y - PATCH_Y0) <= 1.0e-8)
    if not np.any(mask):
        dxy = (x - PATCH_X0) ** 2 + (y - PATCH_Y0) ** 2
        nearest = float(np.min(dxy))
        mask = dxy <= nearest + 1.0e-18
    depth = Z_TOP - z[mask]
    fb = data["fb"][mask]
    order = np.argsort(depth)
    return depth[order], fb[order]


def surface_line_profile(data):
    x = data["x"]
    y = data["y"]
    z = data["z"]
    mask = top_mask(data) & (np.abs(y - PATCH_Y0) <= 1.0e-8)
    if not np.any(mask):
        top = top_mask(data)
        dy = np.abs(y[top] - PATCH_Y0)
        nearest = float(np.min(dy))
        mask = top & (np.abs(y - PATCH_Y0) <= nearest + 1.0e-18)
    order = np.argsort(x[mask])
    return x[mask][order], data["fb"][mask][order]


def print_case_summary(name, data):
    top_fb, top_idx = max_fb(data, top_mask(data))
    hot_fb, hot_idx = max_fb(data, heated_top_mask(data))
    center_fb, center_idx = center_surface_fb(data)
    hot_fb_ex, hot_ex_idx = max_fb_extrap(data, extrap_top_mask_heated(data))
    center_fb_ex, _ = center_surface_fb_extrap(data)
    print(f"{data['label']}: loaded {os.path.basename(data['path'])} at t={data['time']:.2f} s")
    print(
        f"  max top-plane (sampled) f_b={top_fb:.4f} at "
        f"({data['x'][top_idx]:.4f},{data['y'][top_idx]:.4f},{data['z'][top_idx]:.4f})"
    )
    print(
        f"  max heated-surface (sampled) f_b={hot_fb:.4f} at "
        f"({data['x'][hot_idx]:.4f},{data['y'][hot_idx]:.4f},{data['z'][hot_idx]:.4f})"
    )
    print(
        f"  centre surface (sampled) f_b={center_fb:.4f} at "
        f"({data['x'][center_idx]:.4f},{data['y'][center_idx]:.4f},{data['z'][center_idx]:.4f})"
    )
    print(
        f"  max heated-surface (z=0.10 extrapolated) f_b={hot_fb_ex:.4f} at "
        f"({data['x_top'][hot_ex_idx]:.4f},{data['y_top'][hot_ex_idx]:.4f})"
    )
    print(f"  centre surface (z=0.10 extrapolated) f_b={center_fb_ex:.4f}")
    if data["hu_fb"] is not None:
        print(f"  Hu onset target max surface f_b={data['hu_fb']:.2f}")
    return top_fb, hot_fb, center_fb, hot_fb_ex, center_fb_ex


def plot_results(results, out_png):
    try:
        import matplotlib

        matplotlib.use("Agg")
        import matplotlib.pyplot as plt
    except ImportError:
        print("(matplotlib not installed - skipping PNG plot)")
        return

    fig, axes = plt.subplots(1, 3, figsize=(14, 4.2))

    for ax, key, title in [
        (axes[0], "granite37", "Granite 2 surface f_b at 37 s (z=0.10 extrap)"),
        (axes[1], "sandstone89", "Sandstone 2 surface f_b at 89 s (z=0.10 extrap)"),
    ]:
        data = results[key]
        sc = ax.scatter(
            data["x_top"],
            data["y_top"],
            c=data["fb_top"],
            s=12,
            cmap="magma",
            vmin=0.0,
        )
        circle = plt.Circle(
            (PATCH_X0, PATCH_Y0),
            PATCH_RADIUS,
            fill=False,
            color="white",
            linewidth=1.0,
        )
        ax.add_patch(circle)
        ax.set_aspect("equal")
        ax.set_title(title)
        ax.set_xlabel("x [m]")
        ax.set_ylabel("y [m]")
        fig.colorbar(sc, ax=ax, shrink=0.82)

    for key, label, color in [
        ("granite37", "Granite 2, 37 s", "C0"),
        ("sandstone37", "Sandstone 2, 37 s", "C1"),
    ]:
        depth, fb = centerline_profile(results[key])
        axes[2].plot(depth * 1000.0, fb, marker="o", ms=3, lw=1.6,
                     label=label, color=color)
    axes[2].axhline(0.1, color="0.35", ls="--", lw=1.0)
    axes[2].axvline(14.0, color="0.35", ls=":", lw=1.0)
    axes[2].invert_xaxis()
    axes[2].set_xlabel("depth below top surface [mm]")
    axes[2].set_ylabel("centreline f_b")
    axes[2].set_title("L6 depth profile at 37 s")
    axes[2].legend()
    axes[2].grid(alpha=0.3)

    fig.tight_layout()
    os.makedirs(os.path.dirname(out_png), exist_ok=True)
    fig.savefig(out_png, dpi=140)
    print(f"Wrote plot: {out_png}")


def main():
    results = {key: load_fb_case(case) for key, case in CASES.items()}

    ok = True
    summaries = {}
    for key, data in results.items():
        summaries[key] = print_case_summary(key, data)

    granite_hot = summaries["granite37"][3]
    sandstone_hot = summaries["sandstone89"][3]
    if abs(granite_hot - HU_FB_GRANITE_ONSET) > FB_ABS_TOL:
        ok = False
        print(
            f"FAIL: Granite 2 heated-surface max f_b (extrapolated to z=0.10) "
            f"{granite_hot:.4f} differs from Hu {HU_FB_GRANITE_ONSET:.2f} by "
            f"{abs(granite_hot - HU_FB_GRANITE_ONSET):.4f} > {FB_ABS_TOL:.2f}"
        )
    if abs(sandstone_hot - HU_FB_SANDSTONE_ONSET) > FB_ABS_TOL:
        ok = False
        print(
            f"FAIL: Sandstone 2 heated-surface max f_b (extrapolated to z=0.10) "
            f"{sandstone_hot:.4f} differs from Hu {HU_FB_SANDSTONE_ONSET:.2f} by "
            f"{abs(sandstone_hot - HU_FB_SANDSTONE_ONSET):.4f} > {FB_ABS_TOL:.2f}"
        )

    fb_g_center = summaries["granite37"][4]
    fb_s_center = summaries["sandstone37"][4]
    center_margin = 100.0 * (fb_g_center - fb_s_center) / max(fb_s_center, 1.0e-30)
    print(
        f"L5 centre f_b at 37 s: Granite={fb_g_center:.4f}, "
        f"Sandstone={fb_s_center:.4f}, Granite margin={center_margin:+.2f}% "
        f"(Hu +{HU_L5_CENTER_MARGIN_PCT:.2f}%)"
    )
    if fb_g_center <= fb_s_center:
        ok = False
        print("FAIL: Granite 2 f_b is not greater than Sandstone 2 at L5 centre")

    # A slightly stronger heated-zone ordering check: compare the mean along
    # the extrapolated surface line over the circular patch diameter.
    xg, fg = surface_line_profile_extrap(results["granite37"])
    xs, fs = surface_line_profile_extrap(results["sandstone37"])
    patch_g = np.abs(xg - PATCH_X0) <= PATCH_RADIUS + 1.0e-12
    patch_s = np.abs(xs - PATCH_X0) <= PATCH_RADIUS + 1.0e-12
    mean_g = float(np.mean(fg[patch_g]))
    mean_s = float(np.mean(fs[patch_s]))
    print(
        f"L5 heated-zone mean f_b (z=0.10 extrapolated) at 37 s: "
        f"Granite={mean_g:.4f}, Sandstone={mean_s:.4f}"
    )
    if mean_g <= mean_s:
        ok = False
        print("FAIL: Granite 2 f_b is not greater than Sandstone 2 over L5 heated zone")

    for key in ["granite37", "sandstone37"]:
        depth, fb = centerline_profile(results[key])
        deep = depth >= 0.014 - 1.0e-12
        deep_max = float(np.max(fb[deep])) if np.any(deep) else math.inf
        print(
            f"{results[key]['label']} L6 max f_b deeper than 14 mm: "
            f"{deep_max:.4f} (threshold {L6_DEEP_FB_TOL:.2f}; Hu < 0.10 under "
            f"bottom roller, relaxed under bottom-clamp BC)"
        )
        if deep_max >= L6_DEEP_FB_TOL:
            ok = False
            print(
                f"FAIL: {results[key]['label']} has f_b >= {L6_DEEP_FB_TOL:.2f} "
                "deeper than about 14 mm below the heated surface"
            )

    out_png = os.path.join(OUTPUT_ROOT, "comparison.png")
    plot_results(results, out_png)

    print()
    print("PASS" if ok else "FAIL")
    return 0 if ok else 1


if __name__ == "__main__":
    sys.exit(main())
